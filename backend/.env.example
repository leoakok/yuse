# Required
DATABASE_URL=postgres://cvbuilder:cvbuilder@localhost:5432/cvbuilder?sslmode=disable
AUTH_SECRET=change-me-to-match-frontend-auth-secret

# Assistant (optional — without it, sendAssistantMessage returns an error)
OPENAI_API_KEY=
OPENAI_MINI_MODEL=gpt-5.4-mini
# OPENAI_FALLBACK_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o

# GitHub API token (optional fallback for unauthenticated explore — per-user OAuth is preferred)
# Unauthenticated GitHub API is limited to 60 requests/hour per IP; a token raises this to 5000/hr.
GITHUB_TOKEN=

# GitHub OAuth (optional — enables Connections page / per-user repo access)
# Create at https://github.com/settings/developers → OAuth Apps → New OAuth App
# Homepage URL: http://localhost:3000
# Authorization callback URL: http://localhost:3000/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GITHUB_OAUTH_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# Web search fallback (optional — DuckDuckGo is used when unset)
TAVILY_API_KEY=

# LinkedIn profile API (server-side only — never exposed to the frontend)
# LINKEDIN_PROFILE_API_URL=https://www.kocgencyetenek.com/api/linkedin-profile
# LINKEDIN_PROFILE_API_KEY=

# Server
PORT=8080
CORS_ORIGIN=http://localhost:3000

# AWS S3 — profile photo uploads (optional; required for in-app photo upload)
# Flow: backend presigns PUT → browser uploads directly to S3 → photo URL is public GetObject.
# Deploy bucket + IAM user: ./scripts/setup-s3-profile-photos.sh (needs AWS CLI + credentials)
# Template: infra/aws/profile-photos.yaml (stack: yuse-profile-photos, region: eu-west-1)
# AWS_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=yuse-profile-photos-<your-aws-account-id>
# AWS_S3_PUBLIC_URL_PREFIX=   # optional CDN prefix; leave empty for https://<bucket>.s3.<region>.amazonaws.com/
